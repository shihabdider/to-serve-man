---
import type { GetStaticPaths } from "astro";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getLibraryDocument, getLibraryEntries } from "../../lib/content-library";

export const getStaticPaths = (async () => {
  const entries = await getLibraryEntries("recipe");
  return entries.map((entry) => ({ params: { slug: entry.slug } }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
if (slug === undefined) throw new Error("Missing recipe slug for static article route");

const document = await getLibraryDocument("recipe", slug);
if (document === undefined) throw new Error(`Missing recipe document for slug: ${slug}`);

const { Content } = document.rendered;
---

<ArticleLayout entry={document.entry} headings={document.rendered.headings}>
  <Content />
</ArticleLayout>
